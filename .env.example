# TUESDI v3.0 — Plantilla de Variables de Entorno
# Copiar este archivo a .env.local y rellenar con valores reales.
# NUNCA versionear .env.local en Git.

# === SUPABASE ===
# URL del proyecto Supabase (ej: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Clave anónima de Supabase (segura para frontend, solo lectura/inserción según RLS)
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Clave de servicio de Supabase (SECRETO, solo backend/Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# === STRIPE ===
# Clave pública de Stripe (segura para frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Clave secreta de Stripe (SECRETO, solo backend)
STRIPE_SECRET_KEY=sk_test_xxxxx

# Secreto del webhook de Stripe (para validar webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# === AUTENTICACIÓN ===
# Secret para generar Magic Links (mín. 32 caracteres, openssl rand -hex 32)
MAGIC_LINK_SECRET=xxxxx

# Clave de producción de TUESDI (si aplica)
TUESDI_PROD_KEY=xxxxx

# === RESEND (Email) ===
# API Key de Resend para envío de correos (opcional, si no está configurado no se envían emails)
RESEND_API_KEY=xxxxx

# === SITE URL ===
# URL pública del sitio (para links en emails, etc.)
VITE_SITE_URL=http://localhost:5173
SITE_URL=http://localhost:5173
